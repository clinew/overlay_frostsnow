From 287bb2d03d458d78ea03d61dcd61c01b7eeae042 Mon Sep 17 00:00:00 2001
From: Wade Cline <wadecline@hotmail.com>
Date: Fri, 3 Feb 2017 21:15:17 -0800
Subject: [PATCH 2/6] Add logging for OpenSSL connections.

Specifically, log both handshake failures and certificiate
verification.
---
 include/modules/ssl.h               |   2 +
 src/modules/extra/m_ssl_openssl.cpp | 188 ++++++++++++++++++++--------
 2 files changed, 138 insertions(+), 52 deletions(-)

diff --git a/include/modules/ssl.h b/include/modules/ssl.h
index 865ad638f..1edd6093f 100644
--- a/include/modules/ssl.h
+++ b/include/modules/ssl.h
@@ -48,6 +48,7 @@ public:
 	bool invalid = true;
 	bool unknownsigner = true;
 	bool revoked = false;
+	bool exists = false;
 	time_t activation = 0;
 	time_t expiration = 0;
 
@@ -195,6 +196,7 @@ protected:
 	/** Peer TLS certificate, set by the TLS module
 	 */
 	reference<ssl_cert> certificate;
+	std::vector<reference<ssl_cert>> chain;
 
 	/** The status of the TLS connection. */
 	Status status = STATUS_NONE;
diff --git a/src/modules/extra/m_ssl_openssl.cpp b/src/modules/extra/m_ssl_openssl.cpp
index e5f05b586..39a223593 100644
--- a/src/modules/extra/m_ssl_openssl.cpp
+++ b/src/modules/extra/m_ssl_openssl.cpp
@@ -546,37 +546,88 @@ private:
 	SSL* sess;
 	bool data_to_write = false;
 
+	void PrintCertificate(ssl_cert* cert, int i)
+	{
+		if (!cert->exists)
+			return;
+		ServerInstance->Logs.Normal(MODNAME,
+			"{}  s:{}", i, cert->GetDN().c_str());
+		ServerInstance->Logs.Normal(MODNAME,
+			"   i:{}", cert->GetIssuer().c_str());
+		ServerInstance->Logs.Normal(MODNAME,
+			"   fp:{}", cert->GetFingerprint().c_str());
+	}
+
+	void PrintChain()
+	{
+		PrintCertificate(certificate, 0);
+		for (unsigned i = 0; i < chain.size(); i++)
+		{
+			PrintCertificate(chain.at(i), i + 1);
+		}
+	}
+
 	// Returns 1 if handshake succeeded, 0 if it is still in progress, -1 if it failed
 	int Handshake(StreamSocket* user)
 	{
+		irc::sockets::sockaddrs peersockaddr;
+		socklen_t socklen = sizeof(peersockaddr);
+		std::string addrstr;
+		if (getpeername(user->GetFd(), &peersockaddr.sa, &socklen) == -1)
+			addrstr = "unknown";
+		else
+			addrstr = peersockaddr.addr();
+		irc::sockets::sockaddrs localsockaddr;
+		int port;
+		socklen = sizeof(localsockaddr);
+		if (getsockname(user->GetFd(), &localsockaddr.sa, &socklen) == -1)
+			port = -1;
+		else
+			port = localsockaddr.port();
+
 		ERR_clear_error();
 		int ret = SSL_do_handshake(sess);
 		if (ret < 0)
 		{
-			int err = SSL_get_error(sess, ret);
+			// Protocol/connection error.
+			int sslerr = SSL_get_error(sess, ret);
 
-			if (err == SSL_ERROR_WANT_READ)
+			if (sslerr == SSL_ERROR_WANT_READ)
 			{
 				SocketEngine::ChangeEventMask(user, FD_WANT_POLL_READ | FD_WANT_NO_WRITE);
 				this->status = STATUS_HANDSHAKING;
 				return 0;
 			}
-			else if (err == SSL_ERROR_WANT_WRITE)
+			else if (sslerr == SSL_ERROR_WANT_WRITE)
 			{
 				SocketEngine::ChangeEventMask(user, FD_WANT_NO_READ | FD_WANT_SINGLE_WRITE);
 				this->status = STATUS_HANDSHAKING;
 				return 0;
 			}
-			else
-			{
-				CloseSession();
-				return -1;
-			}
 		}
 		else if (ret > 0)
 		{
 			// Handshake complete.
-			VerifyCertificate();
+			VerifyChain();
+
+			if (this->certificate && (!this->certificate->IsCAVerified()))
+			{
+				ServerInstance->Logs.Normal(MODNAME,
+					"Invalid peer certificate chain from "
+					"'{}' port '{}' ('{}'){}",
+					addrstr.c_str(), port,
+					this->certificate->GetError().c_str(),
+					this->certificate->exists ? ":" : "");
+				PrintChain();
+			}
+			else if (this->certificate && this->certificate->IsCAVerified())
+			{
+				ServerInstance->Logs.Normal(MODNAME,
+					"Valid peer certificate chain from "
+					"'{}' port '{}':",
+					addrstr.c_str(), port);
+				PrintChain();
+			}
 
 			status = STATUS_OPEN;
 
@@ -584,10 +635,13 @@ private:
 
 			return 1;
 		}
-		else if (ret == 0)
-		{
-			CloseSession();
-		}
+		int errerr = ERR_get_error();
+		ServerInstance->Logs.Normal(MODNAME,
+			"OpenSSL handshake {} '{}' for '{}' port '{}'",
+			ret ? "error" : "failure",
+			errerr ? ERR_error_string(errerr, NULL) : "unknown",
+			addrstr.c_str(), port);
+		CloseSession();
 		return -1;
 	}
 
@@ -601,10 +655,51 @@ private:
 		sess = nullptr;
 		certificate = nullptr;
 		status = STATUS_NONE;
+		chain.clear();
+	}
+
+	void VerifyCertificate(ssl_cert* certinfo, X509* cert)
+	{
+		GetDNString(X509_get_subject_name(cert), certinfo->dn);
+		GetDNString(X509_get_issuer_name(cert), certinfo->issuer);
+
+		unsigned int mdlen;
+		unsigned char md[EVP_MAX_MD_SIZE];
+		for (const auto* digest : GetProfile().GetDigests())
+		{
+			if (!X509_digest(cert, digest, md, &mdlen))
+			{
+				certinfo->error = "Out of memory generating fingerprint";
+			}
+			else
+			{
+				certinfo->fingerprints.push_back(Hex::Encode(md, mdlen));
+			}
+		}
+
+		certinfo->activation = GetTime(X509_getm_notBefore(cert));
+		certinfo->expiration = GetTime(X509_getm_notAfter(cert));
+
+		int activated = ASN1_TIME_cmp_time_t(X509_getm_notBefore(cert), ServerInstance->Time());
+		if (activated != -1 && activated != 0)
+		{
+			certinfo->error = INSP_FORMAT("Certificate not active for {} (on {})",
+				Duration::ToLongString(certinfo->activation - ServerInstance->Time(), true),
+				Time::ToString(certinfo->activation));
+		}
+
+		int expired = ASN1_TIME_cmp_time_t(X509_getm_notAfter(cert), ServerInstance->Time());
+		if (expired != 0 && expired != 1)
+		{
+			certinfo->error = INSP_FORMAT("Certificate expired {} ago (on {})",
+				Duration::ToLongString(ServerInstance->Time() - certinfo->expiration, true),
+				Time::ToString(certinfo->expiration));
+		}
 	}
 
-	void VerifyCertificate()
+	void VerifyChain()
 	{
+		// Verify leaf peer cert.
 		auto* certinfo = new ssl_cert();
 		this->certificate = certinfo;
 
@@ -614,9 +709,11 @@ private:
 			certinfo->error = "Could not get peer certificate: "+std::string(get_error());
 			return;
 		}
+		certinfo->exists = true;
 
+		// Unintuitive, but the result only really applies to the whole
+		// chain, so call it once here rather than once per cert.
 		const auto verify = SSL_get_verify_result(sess);
-
 		auto selfsigned = false;
 		switch (verify)
 		{
@@ -624,6 +721,7 @@ private:
 			case X509_V_ERR_UNABLE_TO_VERIFY_LEAF_SIGNATURE:
 			case X509_V_ERR_DEPTH_ZERO_SELF_SIGNED_CERT:
 				selfsigned = true;
+				certinfo->error = X509_verify_cert_error_string(verify);
 				[[fallthrough]];
 
 			case X509_V_OK:
@@ -632,9 +730,9 @@ private:
 
 			default:
 				certinfo->invalid = true;
+				certinfo->error = X509_verify_cert_error_string(verify);
 				break;
 		}
-
 		if (selfsigned)
 		{
 			certinfo->unknownsigner = true;
@@ -645,44 +743,28 @@ private:
 			certinfo->unknownsigner = false;
 			certinfo->trusted = true;
 		}
+		VerifyCertificate(certinfo, cert);
+		X509_free(cert);
 
-		GetDNString(X509_get_subject_name(cert), certinfo->dn);
-		GetDNString(X509_get_issuer_name(cert), certinfo->issuer);
-
-		unsigned int mdlen;
-		unsigned char md[EVP_MAX_MD_SIZE];
-		for (const auto* digest : GetProfile().GetDigests())
-		{
-			if (!X509_digest(cert, digest, md, &mdlen))
-			{
-				certinfo->error = "Out of memory generating fingerprint";
-			}
-			else
-			{
-				certinfo->fingerprints.push_back(Hex::Encode(md, mdlen));
-			}
-		}
-
-		certinfo->activation = GetTime(X509_getm_notBefore(cert));
-		certinfo->expiration = GetTime(X509_getm_notAfter(cert));
-
-		int activated = ASN1_TIME_cmp_time_t(X509_getm_notBefore(cert), ServerInstance->Time());
-		if (activated != -1 && activated != 0)
-		{
-			certinfo->error = INSP_FORMAT("Certificate not active for {} (on {})",
-				Duration::ToLongString(certinfo->activation - ServerInstance->Time(), true),
-				Time::ToString(certinfo->activation));
-		}
-
-		int expired = ASN1_TIME_cmp_time_t(X509_getm_notAfter(cert), ServerInstance->Time());
-		if (expired != 0 && expired != 1)
+		// Verify peer chain.
+		STACK_OF(X509)* lchain;
+		lchain = SSL_get_peer_cert_chain(sess);
+		if (!lchain)
+			return;
+		for (int i = 0; i < sk_X509_num(lchain); i++)
 		{
-			certinfo->error = INSP_FORMAT("Certificate expired {} ago (on {})",
-				Duration::ToLongString(ServerInstance->Time() - certinfo->expiration, true),
-				Time::ToString(certinfo->expiration));
+			ssl_cert* chaininfo = new ssl_cert;
+			chaininfo->exists = true;
+			chain.push_back(chaininfo);
+			VerifyCertificate(chaininfo, sk_X509_value(lchain, i));
+			if (chaininfo->error.empty())
+				continue;
+			// Append errors in the chain onto the main cert.
+			if (!certinfo->error.empty())
+				certinfo->error += ", ";
+			certinfo->error += "Cert chain #" +
+				std::to_string(i + 1) + ": " + chaininfo->error;
 		}
-
-		X509_free(cert);
 	}
 
 	static void GetDNString(X509_NAME* x509name, std::string& out)
@@ -1065,7 +1147,9 @@ public:
 		: Module(VF_VENDOR, "Allows TLS encrypted connections using the OpenSSL library.")
 	{
 		// Initialize OpenSSL
-		OPENSSL_init_ssl(0, nullptr);
+		if (!(OPENSSL_init_ssl(OPENSSL_INIT_LOAD_SSL_STRINGS, NULL))) {
+			throw ModuleException(this, "Unable to initialize OpenSSL");
+		}
 		biomethods = OpenSSL::BIOMethod::alloc();
 
 		thismod = this;
-- 
2.51.2

